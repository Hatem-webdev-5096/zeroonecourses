# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=your_render_database_url
DB_PORT=5432
DB_NAME=zero_one_courses

# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Configuration (Generate a strong secret key)
JWT_SECRET=your_secure_jwt_secret_here_at_least_32_characters_long

# Cloudinary Configuration (From your Cloudinary account)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS Configuration (Update with your frontend URL)
FRONTEND_URL=https://your-frontend-url.onrender.com
